generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String
  org       String?
  title     String?
  teamRole  String?
  specialty String?
  createdAt DateTime @default(now())
  todos     Todo[]
}

model Channel {
  id    String @id
  level String
  dept  String
  name  String
  flow  String
}

model Project {
  id            String   @id
  code          String   @unique
  name          String
  goal          String?
  level         String
  channelId     String
  channelName   String
  org           String
  owner         String
  ownerId       String?
  techOwner     String?
  pmName        String?
  chiefL1       String?
  chiefL2       String?
  initDept      String?
  partnerUnit1  String?
  partnerWork1  String?
  partnerUnit2  String?
  partnerWork2  String?
  partnerUnitsExtra String?
  mgmtHqDirector    String?
  mgmtHqSupervisor  String?
  mgmtUnitMinister  String?
  mgmtUnitSupervisor String?
  financeHq           String?
  financeUnitMinister String?
  financeUnitSupervisor String?
  flowStep      Int      @default(0)
  phase         String
  risk          String   @default("blue")
  budgetTotal   Float    @default(0)
  budgetSpent   Float    @default(0)
  budgetYear    Float    @default(0)
  budgetYearSpent Float  @default(0)
  startDate     String?
  endDate       String?
  outcomeStatus String?
  status        String   @default("进行中")
  over100M      Boolean  @default(false)
  postEvalStatus String  @default("pending")
  mainWork      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  milestones    Milestone[]
  partners      Partner[]
  outcomes      Outcome[]
  deliverables  Deliverable[]
  files         ProjectFile[]
  todos         Todo[]
  audits        AuditLog[]
}

model Milestone {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  year        Int
  title       String
  yearGoal    String?
  planContent String?
  dueDate     String?
  status      String  @default("进行中")
  risk        String  @default("blue")
  completion  String?
  planStatus  String?
}

model Partner {
  id           String  @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  type         String
  evaluator    String?
  score        Float?
  level        String?
  evalStatus   String  @default("待评价")
  postEval     String  @default("—")
  evalDate     String?
  blacklisted  Boolean @default(false)
}

model Outcome {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String
  name        String
  method      String?
  form        String?
  status      String  @default("技术储备待应用")
  planDate    String?
  actualDate  String?
  summary     String?
  transformBrief String?
  responsibleUnit String?
  deliverableCount Int @default(0)
}

model Deliverable {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  type        String
  status      String  @default("待交付")
  risk        String  @default("blue")
  ownership   String?
  outcomeCode String?
}

model Todo {
  id        String   @id @default(cuid())
  title     String
  type      String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  roles     String
  orgs      String?
  status    String   @default("pending")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  actor     String
  action    String
  detail    String?
  source    String   @default("human")
  createdAt DateTime @default(now())
}

model Personnel {
  id        String @id @default(cuid())
  name      String
  specialty String
  org       String?
}

model Application {
  id        String   @id @default(cuid())
  level     String
  channelId String
  channelName String
  org       String
  applicant String
  status    String   @default("draft")
  payload   String
  createdAt DateTime @default(now())
  files     ProjectFile[]
}

model ProjectFile {
  id           String   @id @default(cuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  applicationId String?
  application  Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  folderName   String
  relativePath String
  fileName     String
  mimeType     String?
  size         Int      @default(0)
  storageKey   String
  uploadedBy   String
  createdAt    DateTime @default(now())
}
